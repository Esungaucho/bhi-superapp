{
  "name": "SyncLog",
  "type": "object",
  "properties": {
    "source_name": {
      "type": "string",
      "description": "Display name of the event source"
    },
    "source_key": {
      "type": "string",
      "description": "Source identifier e.g. bhi_conservancy"
    },
    "source_url": {
      "type": "string",
      "description": "URL that was synced"
    },
    "status": {
      "type": "string",
      "enum": [
        "connected",
        "failed",
        "needs_manual_setup",
        "requires_admin_review"
      ],
      "default": "connected",
      "description": "Outcome of the sync attempt"
    },
    "events_found": {
      "type": "number",
      "default": 0
    },
    "events_imported": {
      "type": "number",
      "default": 0
    },
    "events_updated": {
      "type": "number",
      "default": 0
    },
    "events_failed": {
      "type": "number",
      "default": 0,
      "description": "Events that failed to import"
    },
    "duplicates_skipped": {
      "type": "number",
      "default": 0
    },
    "extraction_method": {
      "type": "string",
      "enum": [
        "json_ld",
        "llm_html",
        "llm_pdf",
        "manual",
        "auto"
      ],
      "default": "auto",
      "description": "How events were extracted from this source"
    },
    "error_message": {
      "type": "string",
      "description": "Error details if failed"
    },
    "notes": {
      "type": "string",
      "description": "Additional context"
    },
    "sync_type": {
      "type": "string",
      "enum": [
        "manual",
        "scheduled",
        "admin_trigger",
        "per_source"
      ],
      "default": "admin_trigger"
    }
  },
  "required": [
    "source_name",
    "status"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {
      "user_condition": {
        "role": "admin"
      }
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}