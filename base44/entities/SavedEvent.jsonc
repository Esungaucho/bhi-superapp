{
  "name": "SavedEvent",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string",
      "description": "User email"
    },
    "event_id": {
      "type": "string",
      "description": "ID of the saved IslandEvent"
    },
    "rsvp_status": {
      "type": "string",
      "enum": [
        "going",
        "interested",
        "maybe"
      ],
      "default": "going"
    },
    "reminder_set": {
      "type": "boolean",
      "default": true,
      "description": "Send reminder before event"
    },
    "notify_24h": {
      "type": "boolean",
      "default": true,
      "description": "Notify 24 hours before event"
    },
    "notify_2h": {
      "type": "boolean",
      "default": true,
      "description": "Notify 2 hours before event"
    },
    "notify_30m": {
      "type": "boolean",
      "default": false,
      "description": "Notify 30 minutes before event"
    },
    "added_to_trip": {
      "type": "boolean",
      "default": false,
      "description": "Added to user's trip itinerary"
    }
  },
  "required": [
    "user_email",
    "event_id"
  ],
  "rls": {
    "create": {
      "data.user_email": "{{user.email}}"
    },
    "read": {
      "data.user_email": "{{user.email}}"
    },
    "update": {
      "data.user_email": "{{user.email}}"
    },
    "delete": {
      "data.user_email": "{{user.email}}"
    }
  }
}